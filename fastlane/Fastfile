require 'base64'

default_platform(:ios)

platform :ios do

  before_all do
    ensure_bundle_exec
  end

  desc "Build and upload to TestFlight"
  lane :beta do

    setup_ci

    api_key = app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:           ENV["APP_STORE_CONNECT_KEY_BASE64"],
      is_key_content_base64: true
    )

    # Write API key .p8 to a temp file so xcodebuild can authenticate
    key_id      = ENV["APP_STORE_CONNECT_KEY_ID"]
    issuer_id   = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_content = Base64.decode64(ENV["APP_STORE_CONNECT_KEY_BASE64"])
    key_path    = "/tmp/AuthKey_#{key_id}.p8"
    File.write(key_path, key_content)

    install_provisioning_profile(
      path: "DrinkScan_Distribution.mobileprovision"
    )

    update_app_identifier(
      xcodeproj:      "ios/DrinkScanAI.xcodeproj",
      plist_path:     "DrinkScanAI/Info.plist",
      app_identifier: "com.drinkscanai"
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      path:                  "ios/DrinkScanAI.xcodeproj",
      team_id:               "THN78NT3R9"
    )

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj:    "ios/DrinkScanAI.xcodeproj"
    )

    cocoapods(
      clean_install: true,
      podfile:       "ios/Podfile"
    )

    build_app(
      workspace:        "ios/DrinkScanAI.xcworkspace",
      scheme:           "DrinkScanAI",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "DrinkScanAI.ipa",
      clean:            true,
      xcargs:           "-allowProvisioningUpdates -authenticationKeyPath \"#{key_path}\" -authenticationKeyID #{key_id} -authenticationKeyIssuerID #{issuer_id}",
      export_options: {
        provisioningProfiles: {
          "com.drinkscanai" => "DrinkScan Distribution"
        }
      }
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "Automated build from GitHub Actions"
    )

    UI.success "Successfully uploaded to TestFlight!"
  end

  error do |lane, exception|
    UI.error "Lane #{lane} failed: #{exception.message}"
  end

end
