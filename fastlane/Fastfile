require 'base64'

default_platform(:ios)

platform :ios do

  before_all do
    ensure_bundle_exec
  end

  desc "Build and upload to TestFlight"
  lane :beta do

    # NOTE: setup_ci and import_certificate are intentionally skipped
    # The keychain is created and the certificate is imported in the
    # GitHub Actions workflow step before Fastlane runs, using a known
    # password so set-key-partition-list can pre-authorize codesign.

    api_key = app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:           ENV["APP_STORE_CONNECT_KEY_BASE64"],
      is_key_content_base64: true
    )

    install_provisioning_profile(
      path: "DrinkScan_Distribution.mobileprovision"
    )

    update_app_identifier(
      xcodeproj:      "ios/DrinkScanAI.xcodeproj",
      plist_path:     "DrinkScanAI/Info.plist",
      app_identifier: "com.drinkscanai"
    )


    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "ios/DrinkScanAI.xcodeproj",
      code_sign_identity:    "iPhone Distribution",
      profile_name:          "DrinkScan Distribution",
      team_id:               "THN78NT3R9",
      bundle_identifier:     "com.drinkscanai"
    )

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj:    "ios/DrinkScanAI.xcodeproj"
    )

    # Step 1: Archive with signing disabled on frameworks (prevents Embed hang)
    build_app(
      workspace:        "ios/DrinkScanAI.xcworkspace",
      scheme:           "DrinkScanAI",
      configuration:    "Release",
      skip_package_ipa: true,
      archive_path:     "./build/DrinkScanAI.xcarchive",
      xcargs:           "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO IPHONEOS_DEPLOYMENT_TARGET=18.0",
      output_directory: "./build",
      xcodebuild_formatter: ""
    )

    # Step 2: Export with proper signing — codesign pre-authorized via workflow
    build_app(
      workspace:          "ios/DrinkScanAI.xcworkspace",
      skip_build_archive: true,
      archive_path:       "./build/DrinkScanAI.xcarchive",
      export_method:      "app-store",
      output_directory:   "./build",
      output_name:        "DrinkScanAI.ipa",
      export_options: {
        method:               "app-store",
        signingStyle:         "manual",
        teamID:               "THN78NT3R9",
        provisioningProfiles: {
          "com.drinkscanai" => "DrinkScan Distribution"
        }
      }
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "Automated build from GitHub Actions"
    )

    UI.success "Successfully uploaded to TestFlight! 🎉"
  end

  error do |lane, exception|
    UI.error "Lane #{lane} failed: #{exception.message}"
  end

end
