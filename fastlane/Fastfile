require 'base64'

default_platform(:ios)

platform :ios do

  before_all do
    ensure_bundle_exec
  end

  desc "Build and upload to TestFlight"
  lane :beta do

    setup_ci

    api_key = app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:           ENV["APP_STORE_CONNECT_KEY_BASE64"],
      is_key_content_base64: true
    )

    import_certificate(
      certificate_path:     "distribution.p12",
      certificate_password: ENV["CERTIFICATE_PASSWORD"].to_s.strip,
      keychain_name:        "fastlane_tmp_keychain",
      keychain_password:    "fastlane_tmp_keychain_password"
    )

    install_provisioning_profile(
      path: "DrinkScan_Distribution.mobileprovision"
    )

    update_app_identifier(
      xcodeproj:      "ios/DrinkScanAI.xcodeproj",
      plist_path:     "DrinkScanAI/Info.plist",
      app_identifier: "com.drinkscanai"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "ios/DrinkScanAI.xcodeproj",
      code_sign_identity:    "iPhone Distribution",
      profile_name:          "DrinkScan Distribution",
      team_id:               "THN78NT3R9",
      bundle_identifier:     "com.drinkscanai"
    )

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj:    "ios/DrinkScanAI.xcodeproj"
    )

    # NOTE: cocoapods already runs in the workflow before this step
    # Do NOT call cocoapods here — it would reinstall without cache

    # Archive with signing disabled — prevents the Embed Pods Frameworks hang
    # Signing is applied separately in the export step via export_options
    build_app(
      workspace:         "ios/DrinkScanAI.xcworkspace",
      scheme:            "DrinkScanAI",
      configuration:     "Release",
      output_directory:  "./build",
      output_name:       "DrinkScanAI.ipa",
      xcargs:            "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
      export_method:     "app-store",
      export_options: {
        method:               "app-store",
        signingStyle:         "manual",
        signingCertificate:   "iPhone Distribution: #{ENV['TEAM_NAME'] || 'Apple Distribution'}",
        teamID:               "THN78NT3R9",
        provisioningProfiles: {
          "com.drinkscanai" => "DrinkScan Distribution"
        }
      }
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "Automated build from GitHub Actions"
    )

    UI.success "Successfully uploaded to TestFlight!"
  end

  error do |lane, exception|
    UI.error "Lane #{lane} failed: #{exception.message}"
  end

end
